---
import BaseHead from '../layouts/BaseHead.astro';

// Tools (gaming calculators and utilities)
const tools = [
  { emoji: "🖱️", name: "DPI & Sensitivity Matcher", slug: "/dpi-calculator", desc: "Match sensitivity across different DPI settings and mice" },
  { emoji: "👁️", name: "FOV Calculator", slug: "/fov-calculator", desc: "Find ideal field of view based on monitor size and distance" },
  { emoji: "📐", name: "Crosshair Generator", slug: "/crosshair-generator", desc: "Design crosshairs for Valorant, CS2, Overwatch, and more" },
  { emoji: "🖥️", name: "Resolution Scaler", slug: "/resolution-scaler", desc: "Render resolution percentages and performance impact estimates" },
  { emoji: "📊", name: "FPS Calculator", slug: "/fps-calculator", desc: "Estimate FPS for hardware and game settings combinations" },
  { emoji: "💻", name: "PC Bottleneck Calculator", slug: "/bottleneck-calculator", desc: "Check CPU vs GPU bottleneck with upgrade recommendations" },
  { emoji: "⏱️", name: "Input Lag Calculator", slug: "/input-lag", desc: "Calculate total system input lag from mouse to display" },
  { emoji: "🎲", name: "Loot Drop Calculator", slug: "/loot-probability", desc: "Calculate true chances of rare drops with bad luck protection" },
  { emoji: "🕐", name: "Discord Timestamp Generator", slug: "/discord-timestamp", desc: "Generate Discord timestamp codes from any date and time" },
  { emoji: "⌨️", name: "Keybind Planner", slug: "/keybind-planner", desc: "Plan keybinds with visual layout and conflict detection" },
  { emoji: "💥", name: "Damage Calculator", slug: "/damage-calculator", desc: "Calculate DPS, TTK with armor and headshot multipliers" },
  { emoji: "📈", name: "XP Calculator", slug: "/xp-calculator", desc: "Estimate time to level up with XP rates and boosts" },
  { emoji: "📡", name: "Stream Bitrate Calculator", slug: "/stream-bitrate", desc: "Find optimal bitrate for resolution, FPS, and platform" },
  { emoji: "🎯", name: "Aim Stats Calculator", slug: "/aim-trainer-stats", desc: "Calculate aim training metrics and improvement rates" },
  { emoji: "🖥️", name: "Gaming PC Builder", slug: "/gaming-pc-builder", desc: "Build balanced PC for budget with compatibility checks" },
  { emoji: "🎨", name: "Color Blind Test", slug: "/color-blind-test", desc: "Test color vision with gaming-specific scenarios" },
  { emoji: "🎲", name: "Randomizer", slug: "/randomizer", desc: "Random game picker, team generator, map randomizer" },
  { emoji: "🖥️", name: "Monitor Refresh Rate Test", slug: "/refresh-rate-test", desc: "Verify monitor refresh rate and detect frame skipping" }
];

// Studies 
const studies = [
  { emoji: "💻", name: "GPU Performance Index 2026", slug: "/gpu-performance-index", desc: "60 GPUs benchmarked and ranked from RTX 4090 to RX 7600", stat: "60", statLabel: "GPUs ranked" }
];

// Guides
const guides = [
  { emoji: "📺", name: "Streaming Setup Guide", slug: "/guide-streaming-setup", desc: "Complete streaming setup: OBS, audio, lighting, overlays" },
  { emoji: "⌨️", name: "Mechanical Keyboards Guide", slug: "/guide-mechanical-keyboards", desc: "Switches, actuation, polling rate, and recommendations" },
  { emoji: "🖱️", name: "Mouse Grip Styles Guide", slug: "/guide-mouse-grip", desc: "Palm, claw, fingertip grips with mouse recommendations" },
  { emoji: "📚", name: "FPS Optimization Guide", slug: "/guide-fps-optimization", desc: "Windows settings, drivers, in-game settings, hardware" },
  { emoji: "📚", name: "Monitor Buying Guide", slug: "/guide-monitor-buying", desc: "Panel types, refresh rate, response time, resolution" }
];

// Lists
const lists = [
  { emoji: "📋", name: "Best Free-to-Play Games", slug: "/list-free-games", desc: "Top F2P games: Valorant, Fortnite, Apex, LoL, Genshin" },
  { emoji: "🎧", name: "Best Gaming Headsets", slug: "/list-gaming-headsets", desc: "Wireless, wired, budget, premium headsets compared" },
  { emoji: "🎮", name: "Best Game Engines", slug: "/list-game-engines", desc: "Unity, Unreal, Godot comparison with use cases" },
  { emoji: "🤖", name: "Best Discord Bots", slug: "/list-discord-bots", desc: "Top Discord bots for gaming servers and communities" },
  { emoji: "🖱️", name: "Best Gaming Mice", slug: "/list-gaming-mice", desc: "Gaming mice by grip style, weight, sensor, polling rate" }
];
---
<html lang="en">
<head>
  <BaseHead />
  <title>leeroyjenkins.quest — Gaming Tools & Data</title>
  <meta name="description" content="Free gaming tools: DPI sensitivity matcher, FOV calculator, eDPI calculator, polling rate comparison, crosshair generator, and esports setup guides." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, sans-serif; 
      background: #060a12; 
      color: #c8d0de; 
      line-height: 1.6;
    }

    /* Hero */
    .hero { 
      text-align: center; 
      padding: 100px 24px 70px; 
      background: linear-gradient(180deg, #120e1e 0%, #060a12 100%); 
      position: relative; 
    }
    .hero::before { 
      content: ''; 
      position: absolute; 
      inset: 0; 
      background: radial-gradient(circle at 50% 40%, rgba(147,51,234,0.08) 0%, transparent 60%); 
    }
    .hero-content { position: relative; z-index: 1; }
    .hero .tagline { 
      color: #9333EA; 
      font-size: 0.85rem; 
      font-weight: 700; 
      letter-spacing: 3px; 
      text-transform: uppercase; 
      margin-bottom: 16px; 
    }
    .hero h1 { 
      font-size: 3rem; 
      font-weight: 900; 
      letter-spacing: -1.5px; 
      margin-bottom: 8px; 
      background: linear-gradient(135deg, #fff 0%, #9333EA 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero .sub { 
      color: #5a6a80; 
      font-size: 0.9rem; 
      font-style: italic; 
      margin-bottom: 16px; 
    }
    .hero p { 
      color: #5a6a80; 
      font-size: 1.05rem; 
      max-width: 520px; 
      margin: 0 auto; 
    }

    /* Sections */
    .section-container { 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 60px 24px; 
    }
    .section-header { 
      text-align: center; 
      margin-bottom: 40px; 
    }
    .section-tag { 
      display: inline-block; 
      background: rgba(147,51,234,0.1); 
      color: #9333EA; 
      font-size: 0.7rem; 
      font-weight: 800; 
      padding: 6px 16px; 
      border-radius: 20px; 
      letter-spacing: 1px; 
      margin-bottom: 12px; 
    }
    .section-title { 
      font-size: 2.2rem; 
      font-weight: 900; 
      color: #fff; 
      margin-bottom: 8px; 
      letter-spacing: -0.8px; 
    }
    .section-sub { 
      color: #5a6a80; 
      font-size: 1rem; 
    }

    /* Tools Grid */
    .tools-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 16px; 
    }
    .tool-card { 
      background: #100e18; 
      border: 1px solid #221e30; 
      border-radius: 12px; 
      padding: 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .tool-card:hover { 
      border-color: #9333EA; 
      transform: translateY(-2px); 
    }
    .tool-emoji { 
      font-size: 1.4rem; 
      margin-bottom: 8px; 
      display: block; 
    }
    .tool-name { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .tool-desc { 
      font-size: 0.8rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Studies Grid */
    .studies-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
      gap: 24px; 
    }
    .study-card { 
      background: linear-gradient(135deg, #0e0c14 0%, #150e20 100%); 
      border: 1px solid #221e30; 
      border-radius: 16px; 
      padding: 28px 24px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.3s ease; 
      position: relative; 
      overflow: hidden; 
    }
    .study-card::before { 
      content: ''; 
      position: absolute; 
      top: 0; 
      left: 0; 
      right: 0; 
      height: 2px; 
      background: linear-gradient(90deg, #9333EA, #A855F7); 
      opacity: 0; 
      transition: opacity 0.3s; 
    }
    .study-card:hover { 
      border-color: #9333EA; 
      transform: translateY(-3px); 
      box-shadow: 0 12px 40px rgba(147,51,234,0.15); 
    }
    .study-card:hover::before { opacity: 1; }
    
    .study-emoji { 
      font-size: 1.6rem; 
      margin-bottom: 12px; 
      display: block; 
    }
    .study-stat { 
      margin-bottom: 16px; 
    }
    .stat-number { 
      display: block; 
      font-size: 2rem; 
      font-weight: 900; 
      color: #9333EA; 
      line-height: 1; 
      letter-spacing: -1px; 
    }
    .stat-label { 
      display: block; 
      font-size: 0.75rem; 
      color: #5a6a80; 
      margin-top: 4px; 
    }
    .study-name { 
      font-size: 1rem; 
      font-weight: 800; 
      color: #e0e8f0; 
      margin-bottom: 8px; 
      line-height: 1.3; 
    }
    .study-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Guides & Lists Grid */
    .guides-grid, .lists-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
      gap: 20px; 
    }
    .guide-card, .list-card { 
      background: #100e18; 
      border: 1px solid #221e30; 
      border-radius: 14px; 
      padding: 24px 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .guide-card:hover, .list-card:hover { 
      border-color: #9333EA; 
      transform: translateY(-2px); 
    }
    .guide-emoji, .list-emoji { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
      display: block; 
    }
    .guide-name, .list-name { 
      font-size: 1rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .guide-desc, .list-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Footer */
    .footer { 
      text-align: center; 
      padding: 50px 24px; 
      font-size: 0.85rem; 
      color: #3a4a5a; 
      border-top: 1px solid #151f2e; 
      background: #040810; 
    }
    .footer a { 
      color: #9333EA; 
      text-decoration: none; 
    }
    .footer a:hover { 
      text-decoration: underline; 
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .section-container { padding: 40px 20px; }
      .tools-grid, .studies-grid, .guides-grid, .lists-grid { 
        grid-template-columns: 1fr; 
      }
    }
  </style>
</head>
<body>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Gaming Tools & Data</div>
      <h1>leeroyjenkins.quest</h1>
      <div class="sub">"At least I have chicken."</div>
      <p>Gaming research & tools. Benchmarks, sensitivity calculators, and esports utilities.</p>
    </div>
  </div>

  <!-- Tools Section -->
  {tools.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🛠️ TOOLS</span>
        <h2 class="section-title">Gaming Tools</h2>
        <p class="section-sub">Free, client-side, no signup.</p>
      </div>
      <div class="tools-grid">
        {tools.map(tool => (
          <a class="tool-card" href={tool.slug}>
            <span class="tool-emoji">{tool.emoji}</span>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Studies Section -->
  {studies.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🔬 RESEARCH</span>
        <h2 class="section-title">Featured Studies</h2>
        <p class="section-sub">Real benchmark data. No sponsored BS.</p>
      </div>
      <div class="studies-grid">
        {studies.map(study => (
          <a class="study-card" href={study.slug}>
            <span class="study-emoji">{study.emoji}</span>
            <div class="study-stat">
              <span class="stat-number">{study.stat}</span>
              <span class="stat-label">{study.statLabel}</span>
            </div>
            <h3 class="study-name">{study.name}</h3>
            <p class="study-desc">{study.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Guides Section -->
  {guides.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📚 GUIDES</span>
        <h2 class="section-title">Gaming Guides</h2>
        <p class="section-sub">Complete guides for competitive gaming and streaming.</p>
      </div>
      <div class="guides-grid">
        {guides.map(guide => (
          <a class="guide-card" href={guide.slug}>
            <span class="guide-emoji">{guide.emoji}</span>
            <h3 class="guide-name">{guide.name}</h3>
            <p class="guide-desc">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Lists Section -->
  {lists.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📋 LISTS</span>
        <h2 class="section-title">Curated Lists</h2>
        <p class="section-sub">Best gaming gear, software, and services ranked.</p>
      </div>
      <div class="lists-grid">
        {lists.map(list => (
          <a class="list-card" href={list.slug}>
            <span class="list-emoji">{list.emoji}</span>
            <h3 class="list-name">{list.name}</h3>
            <p class="list-desc">{list.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    © 2026 <a href="/">leeroyjenkins.quest</a> · A <a href="https://gab.ae">GAB Ventures</a> property
  </div>
</body>
</html>